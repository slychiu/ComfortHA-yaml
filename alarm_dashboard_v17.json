{
  "views": [
    {
      "title": "Home",
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "heading",
              "heading_style": "title"
            },
            {
              "type": "vertical-stack",
              "cards": [
                {
                  "type": "markdown",
                  "title": "Alarm Status",
                  "content": "{% set status = states('alarm_control_panel.comfort_alarm') %} {% if status == 'disarmed' %}\n  System is currently: **System Disarmed**\n{% elif status == 'armed_home' %}\n  System is currently: **System Armed (Home)**\n{% elif status == 'armed_away' %}\n  System is currently: **System Armed (Away)**\n{% elif status == 'armed_night' %}\n  System is currently: **System Armed (Night)**\n{% else %}\n  System is currently: **{{ status | replace('_', ' ') | title }}**\n{% endif %}"
                },
                {
                  "type": "conditional",
                  "conditions": [
                    {
                      "condition": "state",
                      "entity": "alarm_control_panel.comfort_alarm",
                      "state": "disarmed"
                    }
                  ],
                  "card": {
                    "type": "grid",
                    "columns": 3,
                    "square": false,
                    "cards": [
                      {
                        "type": "button",
                        "name": "Away",
                        "icon": "mdi:shield-lock",
                        "tap_action": {
                          "action": "call-service",
                          "service": "script.turn_on",
                          "target": {
                            "entity_id": "script.comfort_arm_away"
                          }
                        }
                      },
                      {
                        "type": "button",
                        "name": "Night",
                        "icon": "mdi:weather-night",
                        "tap_action": {
                          "action": "call-service",
                          "service": "script.turn_on",
                          "target": {
                            "entity_id": "script.comfort_arm_night"
                          }
                        }
                      },
                      {
                        "type": "button",
                        "name": "Day",
                        "icon": "mdi:home-lock",
                        "tap_action": {
                          "action": "call-service",
                          "service": "script.turn_on",
                          "target": {
                            "entity_id": "script.comfort_arm_home"
                          }
                        }
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "grid",
              "title": "Keypad",
              "columns": 3,
              "square": false,
              "cards": [
                {
                  "show_name": true,
                  "show_icon": true,
                  "type": "button",
                  "name": "1",
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_append"
                    },
                    "data": {
                      "variables": {
                        "key": "1"
                      }
                    }
                  }
                },
                {
                  "type": "button",
                  "name": "2",
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_append"
                    },
                    "data": {
                      "variables": {
                        "key": "2"
                      }
                    }
                  }
                },
                {
                  "type": "button",
                  "name": "3",
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_append"
                    },
                    "data": {
                      "variables": {
                        "key": "3"
                      }
                    }
                  }
                },
                {
                  "type": "button",
                  "name": "4",
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_append"
                    },
                    "data": {
                      "variables": {
                        "key": "4"
                      }
                    }
                  }
                },
                {
                  "type": "button",
                  "name": "5",
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_append"
                    },
                    "data": {
                      "variables": {
                        "key": "5"
                      }
                    }
                  }
                },
                {
                  "type": "button",
                  "name": "6",
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_append"
                    },
                    "data": {
                      "variables": {
                        "key": "6"
                      }
                    }
                  }
                },
                {
                  "type": "button",
                  "name": "7",
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_append"
                    },
                    "data": {
                      "variables": {
                        "key": "7"
                      }
                    }
                  }
                },
                {
                  "type": "button",
                  "name": "8",
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_append"
                    },
                    "data": {
                      "variables": {
                        "key": "8"
                      }
                    }
                  }
                },
                {
                  "type": "button",
                  "name": "9",
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_append"
                    },
                    "data": {
                      "variables": {
                        "key": "9"
                      }
                    }
                  }
                },
                {
                  "type": "button",
                  "icon": "mdi:asterisk",
                  "show_name": false,
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_clear"
                    }
                  }
                },
                {
                  "type": "button",
                  "name": "0",
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_append"
                    },
                    "data": {
                      "variables": {
                        "key": "0"
                      }
                    }
                  }
                },
                {
                  "type": "button",
                  "icon": "mdi:pound",
                  "show_name": false,
                  "tap_action": {
                    "action": "perform-action",
                    "perform_action": "script.turn_on",
                    "target": {
                      "entity_id": "script.comfort_pin_submit"
                    }
                  }
                }
              ],
              "card_mod": {
                "style": "ha-card {\n  --grid-card-gap: 6px;\n}\n/* Force row height */\n#root {\n  grid-auto-rows: 60px !important;\n}\n"
              }
            },
            {
              "type": "markdown",
              "title": "Comfort Message",
              "content": "{{ states('input_text.comfort_alarm_message') }}\n"
            }
          ]
        },
        {
          "type": "grid",
          "cards": [
            {
              "type": "vertical-stack",
              "cards": [
                {
                  "type": "custom:auto-entities",
                  "card": {
                    "type": "grid",
                    "title": "Zones",
                    "columns": 4,
                    "square": false
                  },
                  "card_param": "cards",
                  "filter": {
                    "include": [
                      {
                        "entity_id": "binary_sensor.cytech_comfort_mqtt_input*",
                        "options": {
                          "type": "custom:button-card",
                          "show_state": true,
                          "show_icon": true,
                          "state_display": "[[[\n  const name = (entity.attributes.friendly_name || '').toLowerCase();\n  if (name.includes('light')) return entity.state === 'on' ? 'On' : 'Off';\n  if (name.includes('tamper')) return entity.state === 'on' ? 'Tampered' : 'Secure';\n  if (name.includes('panic')) return entity.state === 'on' ? 'PANIC' : 'Normal';\n  if (name.includes('fire') || name.includes('smoke')) return entity.state === 'on' ? 'ALERT' : 'Normal';\n  return entity.state === 'on' ? 'Open' : 'Closed';\n]]]\n",
                          "icon": "[[[\n  const isOff = entity.state === 'off';\n  const name = (entity.attributes.friendly_name || '').toLowerCase();\n  if (name.includes('light')) return isOff ? 'mdi:lightbulb-off' : 'mdi:lightbulb';\n  if (name.includes('door')) return isOff ? 'mdi:door-closed' : 'mdi:door-open';\n  if (name.includes('window')) return isOff ? 'mdi:window-closed' : 'mdi:window-open';\n  if (name.includes('gate')) return isOff ? 'mdi:gate' : 'mdi:gate-open';\n  if (name.includes('pir') || name.includes('motion')) return isOff ? 'mdi:motion-sensor-off' : 'mdi:motion-sensor';\n  if (name.includes('tamper')) return isOff ? 'mdi:lock' : 'mdi:lock-open-alert';\n  if (name.includes('fire') || name.includes('smoke')) return isOff ? 'mdi:smoke-detector-off' : 'mdi:fire-alert';\n  if (name.includes('panic')) return isOff ? 'mdi:alarm-light-off' : 'mdi:alarm-light';\n  return isOff ? 'mdi:shield-check' : 'mdi:shield-alert';\n]]]\n",
                          "name": "[[[\n  let n = entity?.attributes?.friendly_name || entity?.entity_id || 'Zone';\n  n = n.replace(/^Comfort\\s*/i, '');\n  return n.replace(/([a-z])([A-Z])/g, '$1 $2');\n]]]\n",
                          "state": [
                            {
                              "value": "on",
                              "styles": {
                                "card": [
                                  {
                                    "border": "4px solid var(--warning-color)"
                                  }
                                ],
                                "icon": [
                                  {
                                    "color": "yellow"
                                  }
                                ],
                                "name": [
                                  {
                                    "color": "yellow"
                                  },
                                  {
                                    "font-weight": "bold"
                                  },
                                  {
                                    "font-size": "11px"
                                  }
                                ],
                                "state": [
                                  {
                                    "color": "yellow"
                                  },
                                  {
                                    "font-size": "10px"
                                  }
                                ]
                              }
                            },
                            {
                              "value": "off",
                              "styles": {
                                "card": [
                                  {
                                    "border": "1px solid var(--divider-color)"
                                  }
                                ],
                                "icon": [
                                  {
                                    "color": "green"
                                  }
                                ],
                                "name": [
                                  {
                                    "font-size": "11px"
                                  }
                                ],
                                "state": [
                                  {
                                    "font-size": "10px"
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      },
                      {
                        "entity_id": "binary_sensor.comfort_*",
                        "options": {
                          "type": "custom:button-card",
                          "show_state": true,
                          "show_icon": true,
                          "state_display": "[[[\n  const name = (entity.attributes.friendly_name || '').toLowerCase();\n  if (name.includes('light')) return entity.state === 'on' ? 'On' : 'Off';\n  if (name.includes('tamper')) return entity.state === 'on' ? 'Tampered' : 'Secure';\n  if (name.includes('panic')) return entity.state === 'on' ? 'PANIC' : 'Normal';\n  if (name.includes('fire') || name.includes('smoke')) return entity.state === 'on' ? 'ALERT' : 'Normal';\n  return entity.state === 'on' ? 'Open' : 'Closed';\n]]]\n",
                          "icon": "[[[\n  const isOff = entity.state === 'off';\n  const name = (entity.attributes.friendly_name || '').toLowerCase();\n  if (name.includes('light')) return isOff ? 'mdi:lightbulb-off' : 'mdi:lightbulb';\n  if (name.includes('door')) return isOff ? 'mdi:door-closed' : 'mdi:door-open';\n  if (name.includes('window')) return isOff ? 'mdi:window-closed' : 'mdi:window-open';\n  if (name.includes('gate')) return isOff ? 'mdi:gate' : 'mdi:gate-open';\n  if (name.includes('pir') || name.includes('motion')) return isOff ? 'mdi:motion-sensor-off' : 'mdi:motion-sensor';\n  if (name.includes('tamper')) return isOff ? 'mdi:lock' : 'mdi:lock-open-alert';\n  if (name.includes('fire') || name.includes('smoke')) return isOff ? 'mdi:smoke-detector-off' : 'mdi:fire-alert';\n  if (name.includes('panic')) return isOff ? 'mdi:alarm-light-off' : 'mdi:alarm-light';\n  return isOff ? 'mdi:shield-check' : 'mdi:shield-alert';\n]]]\n",
                          "name": "[[[\n  let n = entity?.attributes?.friendly_name || entity?.entity_id || 'Zone';\n  n = n.replace(/^Comfort\\s*/i, '');\n  return n.replace(/([a-z])([A-Z])/g, '$1 $2');\n]]]\n",
                          "state": [
                            {
                              "value": "on",
                              "styles": {
                                "card": [
                                  {
                                    "border": "4px solid var(--warning-color)"
                                  }
                                ],
                                "icon": [
                                  {
                                    "color": "yellow"
                                  }
                                ],
                                "name": [
                                  {
                                    "color": "yellow"
                                  },
                                  {
                                    "font-weight": "bold"
                                  },
                                  {
                                    "font-size": "11px"
                                  }
                                ],
                                "state": [
                                  {
                                    "color": "yellow"
                                  },
                                  {
                                    "font-size": "10px"
                                  }
                                ]
                              }
                            },
                            {
                              "value": "off",
                              "styles": {
                                "card": [
                                  {
                                    "border": "1px solid var(--divider-color)"
                                  }
                                ],
                                "icon": [
                                  {
                                    "color": "green"
                                  }
                                ],
                                "name": [
                                  {
                                    "font-size": "11px"
                                  }
                                ],
                                "state": [
                                  {
                                    "font-size": "10px"
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      }
                    ],
                    "exclude": [
                      {
                        "name": "Zone*"
                      },
                      {
                        "name": "Comfort Zone*"
                      },
                      {
                        "name": "ComfortZone*"
                      },
                      {
                        "entity_id": "binary_sensor.comfort_connected"
                      },
                      {
                        "entity_id": "binary_sensor.comfort_bypass_required"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "vertical-stack",
              "cards": [
                {
                  "show_name": true,
                  "show_icon": true,
                  "type": "button",
                  "icon": "mdi:broom",
                  "name": "Clear",
                  "tap_action": {
                    "action": "call-service",
                    "service": "input_button.press",
                    "data": {
                      "entity_id": "input_button.clear_alarm_log"
                    }
                  },
                  "card_mod": {
                    "style": "ha-card {\n  width: 48px;\n  height: 48px;\n  padding: 4px;\n}\n"
                  }
                },
                {
                  "type": "markdown",
                  "title": "Alarm Message Log",
                  "content": "{{ state_attr('sensor.comfort_mqtt_log', 'log') or '' }}\n",
                  "card_mod": {
                    "style": "ha-card {\n  max-height: 320px;\n  overflow-y: auto;\n}\nha-markdown {\n  max-height: 280px;  /* leaves room for title/padding */\n  overflow-y: auto;\n}\n"
                  }
                }
              ]
            },
            {
              "type": "heading",
              "heading_style": "title",
              "heading": "Log"
            }
          ]
        },
        {
          "type": "grid",
          "cards": [
            {
              "type": "heading",
              "heading_style": "title"
            }
          ]
        }
      ]
    }
  ]
}